# ===== TIÊN ÂM CÁC — Environment Configuration =====
# Copy this file to .env and fill in your values

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- Redis (for Celery task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Ollama (local LLM - FREE, no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
# Alternative: llama3.1:8b, mistral:7b, phi3:mini

# --- Groq API (FREE tier - 30 req/min, backup LLM) ---
GROQ_API_KEY=your_groq_api_key_here
# Get free key at: https://console.groq.com

# --- edge-tts (FREE - no key needed) ---
# Microsoft Edge TTS, just install the package

# --- Freesound API (FREE - CC licensed SFX) ---
FREESOUND_API_KEY=your_freesound_api_key_here
# Get free key at: https://freesound.org/apiv2/apply/

# --- Pixabay API (FREE - royalty-free music) ---
PIXABAY_API_KEY=your_pixabay_api_key_here
# Get free key at: https://pixabay.com/api/docs/

# --- File Storage ---
UPLOAD_DIR=./assets/uploads
OUTPUT_DIR=./assets/output
BGM_DIR=./assets/bgm
SFX_DIR=./assets/sfx

# --- Audio Settings ---
OUTPUT_FORMAT=mp3
OUTPUT_BITRATE=192k
SAMPLE_RATE=44100
MASTER_LUFS=-14
BGM_VOLUME_NORMAL=-18
BGM_VOLUME_DUCKED=-28
SFX_VOLUME=-6
